# Vercel serverless environment variables
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
SCOPUS_API_KEY=optional_scopus_key
WOS_API_KEY=optional_wos_key
SEMANTIC_SCHOLAR_API_KEY=optional_semantic_scholar_key
ALLOWED_ORIGINS=http://localhost:5173,https://yourusername.github.io

# Frontend (Vite) - set in .env.local for local dev
VITE_API_URL=http://localhost:3000

# GitHub Pages build flag
GITHUB_PAGES=true
